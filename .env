APP_NAME=uav-streaming-system

BASE_URL=http://127.0.0.1:8081
TOKEN=uav-local-dev-token
SUBSCRIBE_UAV_ID=1

RTSP_URL=rtsp://192.168.144.25:8554/main.264

FFMPEG_CODEC=copy
FFMPEG_BITRATE=2500k
FFMPEG_MAXRATE=3000k
FFMPEG_BUFSIZE=5000k
FFMPEG_PRESET=veryfast
FFMPEG_TUNE=zerolatency
FFMPEG_GOP=30
FFMPEG_PROFILE=baseline
FFMPEG_LEVEL=3.1
FFMPEG_RTSP_TRANSPORT=tcp

MEDIAMTX_HOST=127.0.0.1
MEDIAMTX_MANAGED=false
MEDIAMTX_BIN=mediamtx
MEDIAMTX_CONFIG_PATH=./app/config/mediamtx.yml
MEDIAMTX_RTSP_PORT=8554
MEDIAMTX_HLS_PORT=8888
MEDIAMTX_WEBRTC_PORT=8889
MEDIAMTX_API_PORT=9997
MEDIAMTX_METRICS_PORT=9998

RECORDS_DIR=./records
RAW_RECORDS_DIR=./records/_raw
HLS_DIR=./hls
LOGS_DIR=./logs

LOG_LEVEL=INFO
