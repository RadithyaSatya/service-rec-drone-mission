APP_NAME=uav-streaming-system

# Base backend untuk auth WS, device-context, dan telemetry subscription.
BASE_URL=http://127.0.0.1:8081
TOKEN=uav-local-dev-token
# ID UAV yang dipakai saat subscribe websocket.
# Ini tidak mengubah URL HLS.
# URL HLS tetap: http://127.0.0.1:8088/hls/index.m3u8
# Nilai ini dipakai untuk:
# 1. filter telemetry websocket
# 2. fallback drone_id jika device-context gagal
SUBSCRIBE_UAV_ID=1

# Sumber video RTSP lokal yang akan diubah ke HLS.
RTSP_URL=rtsp://192.168.144.25:8554/main.264

# Pakai copy jika source sudah H.264 agar hemat CPU.
FFMPEG_CODEC=copy
FFMPEG_BITRATE=2500k
FFMPEG_MAXRATE=3000k
FFMPEG_BUFSIZE=5000k
FFMPEG_PRESET=ultrafast
FFMPEG_TUNE=zerolatency
FFMPEG_GOP=30
FFMPEG_PROFILE=baseline
FFMPEG_LEVEL=3.1
FFMPEG_RTSP_TRANSPORT=tcp
FFMPEG_LOGLEVEL=warning
FFMPEG_RESTART_DELAY_SECONDS=5

IDLE_STREAM_ENABLED=true
MISSION_START_GRACE_SECONDS=1.0

# HLS live output.
HLS_TIME_SECONDS=1
HLS_LIST_SIZE=4
HLS_DELETE_THRESHOLD=1

# FastAPI local server.
SERVER_HOST=0.0.0.0
SERVER_PORT=8088
PUBLIC_BASE_URL=http://127.0.0.1:8088

# Output lokal.
RECORDS_DIR=./records
HLS_DIR=./hls
LOGS_DIR=./logs

LOG_LEVEL=INFO
